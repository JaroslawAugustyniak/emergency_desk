# Production Environment Configuration

# Application
APP_ENV=production
APP_DEBUG=false
APP_NAME=EmergencyDesk

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=emergency_desk_prod
DB_USERNAME=ed_prod_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# Laravel
APP_KEY=base64:GENERATE_THIS_WITH_php_artisan_key:generate

# API
NEXT_PUBLIC_API_URL=https://emergencydesk.augustyniak.xyz/api

# Mail (jeśli potrzebny)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_FROM_ADDRESS=noreply@emergencydesk.ai
