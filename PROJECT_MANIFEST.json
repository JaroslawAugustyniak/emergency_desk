{
  "project": {
    "name": "Emergency Desk",
    "description": "SaaS application for managing emergency repair orders and technician dispatching",
    "version": "1.0.0",
    "startDate": "2026-02-19",
    "targetLaunch": "2026-08-31",
    "status": "In Development",
    "type": "SaaS - Service Management System"
  },
  "team": {
    "owner": "Jaroslaw Augustyniak",
    "email": "ai@awcg.pl",
    "deploymentUrl": "ghcr.io/jaroslawaugustyniak/emergency_desk"
  },
  "architecture": {
    "type": "Monorepo - Frontend + Backend",
    "backend": {
      "framework": "Laravel 11",
      "language": "PHP",
      "authSystem": "Laravel Sanctum",
      "apiFormat": "RESTful JSON",
      "database": "MySQL 8.0",
      "queueSystem": "Database Queue",
      "pdfGenerator": "mPDF or TCPDF",
      "storage": "Local + S3 Compatible",
      "containerization": "Docker",
      "deploymentMethod": "Docker Compose + GitHub Container Registry"
    },
    "frontend": {
      "framework": "Next.js 15+ (App Router)",
      "language": "TypeScript",
      "styling": "Tailwind CSS",
      "uiComponents": "Shadcn/ui or Headless UI",
      "stateManagement": "React Query / TanStack Query",
      "mobileOptimization": "PWA-ready",
      "internationalization": "next-intl",
      "containerization": "Docker",
      "deploymentMethod": "Docker + GitHub Container Registry"
    },
    "infrastructure": {
      "reverseProxy": "Nginx Proxy Manager",
      "ssl": "Let's Encrypt (via Nginx Proxy Manager)",
      "monitoring": "Docker Health Checks",
      "backups": "Cron-based (14-day retention for DB, daily for photos)",
      "externalStorage": "S3 or SFTP",
      "networking": "Docker Bridge + External Nginx Network"
    }
  },
  "database": {
    "engine": "MySQL 8.0",
    "characterSet": "utf8mb4",
    "collation": "utf8mb4_unicode_ci",
    "integrity": "InnoDB with Foreign Keys",
    "softDeletes": "Yes (Laravel Soft Deletes)",
    "backupRetention": "14 days",
    "tables": {
      "users": {
        "description": "User accounts and authentication",
        "fields": [
          { "name": "id", "type": "BIGINT UNSIGNED", "pk": true, "ai": true },
          { "name": "email", "type": "VARCHAR(255)", "unique": true, "required": true },
          { "name": "password", "type": "VARCHAR(255)", "required": true },
          { "name": "role", "type": "ENUM('admin','client','technician')", "required": true },
          { "name": "first_name", "type": "VARCHAR(100)", "required": true },
          { "name": "last_name", "type": "VARCHAR(100)", "required": true },
          { "name": "phone", "type": "VARCHAR(20)" },
          { "name": "created_at", "type": "TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP" },
          { "name": "deleted_at", "type": "TIMESTAMP", "nullable": true }
        ]
      },
      "clients": {
        "description": "Client (zleceniodawca) specific data",
        "fields": [
          { "name": "id", "type": "BIGINT UNSIGNED", "pk": true, "ai": true },
          { "name": "user_id", "type": "BIGINT UNSIGNED", "fk": "users.id", "cascadeDelete": false },
          { "name": "has_internal_no", "type": "BOOLEAN", "default": false },
          { "name": "created_at", "type": "TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP" }
        ]
      },
      "service_categories": {
        "description": "Service categories per client",
        "fields": [
          { "name": "id", "type": "BIGINT UNSIGNED", "pk": true, "ai": true },
          { "name": "client_id", "type": "BIGINT UNSIGNED", "fk": "clients.id", "cascadeDelete": true },
          { "name": "name", "type": "VARCHAR(100)", "required": true },
          { "name": "color", "type": "VARCHAR(7)", "description": "HEX color code", "required": true },
          { "name": "created_at", "type": "TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP" }
        ]
      },
      "addresses": {
        "description": "Predefined address points per client",
        "fields": [
          { "name": "id", "type": "BIGINT UNSIGNED", "pk": true, "ai": true },
          { "name": "client_id", "type": "BIGINT UNSIGNED", "fk": "clients.id", "cascadeDelete": true },
          { "name": "street_no", "type": "VARCHAR(255)", "required": true },
          { "name": "apartment_no", "type": "VARCHAR(50)" },
          { "name": "city", "type": "VARCHAR(100)", "required": true },
          { "name": "created_at", "type": "TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP" }
        ]
      },
      "orders": {
        "description": "Main orders table - core of the system",
        "fields": [
          { "name": "id", "type": "BIGINT UNSIGNED", "pk": true, "ai": true },
          { "name": "order_number", "type": "VARCHAR(100)", "unique": true, "description": "Format: id_client/id_address/id_order" },
          { "name": "client_id", "type": "BIGINT UNSIGNED", "fk": "clients.id", "required": true },
          { "name": "technician_id", "type": "BIGINT UNSIGNED", "fk": "users.id", "nullable": true },
          { "name": "address_id", "type": "BIGINT UNSIGNED", "fk": "addresses.id", "required": true },
          { "name": "category_id", "type": "BIGINT UNSIGNED", "fk": "service_categories.id", "required": true },
          { "name": "status", "type": "ENUM('new','assigned','in_progress','paused','completed','invoiced')", "default": "new" },
          { "name": "description", "type": "TEXT", "description": "Initial problem/order description" },
          { "name": "stop_reason", "type": "TEXT", "nullable": true, "description": "Reason for pausing work" },
          { "name": "vat_rate", "type": "DECIMAL(5,2)", "default": "23.00" },
          { "name": "is_emergency", "type": "BOOLEAN", "default": false, "description": "Emergency/Pogotowie flag" },
          { "name": "client_ref_no", "type": "VARCHAR(100)", "nullable": true, "description": "Client's internal order number" },
          { "name": "invoice_no", "type": "VARCHAR(100)", "nullable": true },
          { "name": "price_total", "type": "DECIMAL(10,2)", "nullable": true },
          { "name": "work_report", "type": "TEXT", "nullable": true, "description": "Technician's work description" },
          { "name": "order_date", "type": "DATETIME", "required": true },
          { "name": "start_at", "type": "DATETIME", "nullable": true },
          { "name": "end_at", "type": "DATETIME", "nullable": true },
          { "name": "created_at", "type": "TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP" },
          { "name": "deleted_at", "type": "TIMESTAMP", "nullable": true }
        ]
      },
      "order_materials": {
        "description": "Materials used during order execution",
        "fields": [
          { "name": "id", "type": "BIGINT UNSIGNED", "pk": true, "ai": true },
          { "name": "order_id", "type": "BIGINT UNSIGNED", "fk": "orders.id", "cascadeDelete": true },
          { "name": "name", "type": "VARCHAR(255)", "required": true },
          { "name": "price", "type": "DECIMAL(10,2)", "required": true },
          { "name": "created_at", "type": "TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP" }
        ]
      },
      "order_photos": {
        "description": "After-repair photos gallery",
        "fields": [
          { "name": "id", "type": "BIGINT UNSIGNED", "pk": true, "ai": true },
          { "name": "order_id", "type": "BIGINT UNSIGNED", "fk": "orders.id", "cascadeDelete": true },
          { "name": "file_path", "type": "VARCHAR(255)", "required": true },
          { "name": "created_at", "type": "TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP" }
        ]
      }
    }
  },
  "roles": {
    "admin": {
      "label": "Admin Główny",
      "description": "System administrator with full access",
      "permissions": [
        "manage_users",
        "manage_clients",
        "manage_technicians",
        "manage_categories",
        "manage_addresses",
        "create_orders",
        "assign_orders",
        "view_reports",
        "manage_financial_params",
        "generate_invoices",
        "manage_vat",
        "view_all_orders",
        "pause_orders",
        "generate_pdf_reports",
        "send_documents"
      ]
    },
    "client": {
      "label": "Zleceniodawca",
      "description": "Service client submitting and monitoring orders",
      "permissions": [
        "create_own_orders",
        "view_own_orders",
        "view_order_status",
        "provide_order_description",
        "view_assigned_technician",
        "receive_pdf_reports"
      ]
    },
    "technician": {
      "label": "Technik",
      "description": "Field technician executing orders",
      "permissions": [
        "view_assigned_orders",
        "start_order",
        "end_order",
        "add_work_description",
        "add_materials",
        "upload_photos",
        "pause_orders",
        "provide_pause_reason",
        "view_own_analytics"
      ]
    }
  },
